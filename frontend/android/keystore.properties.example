# 안드로이드 서명 키 설정 템플릿
# 이 파일을 복사해서 같은 폴더에 keystore.properties 로 만든 뒤 실제 값으로 채우세요.
#   cp keystore.properties.example keystore.properties
# 실제 keystore.properties 와 .jks 파일은 .gitignore 로 커밋되지 않습니다. (절대 공유 금지)

# 생성한 키스토어(.jks) 경로 — android 폴더 기준 상대경로 또는 절대경로
storeFile=tickjapan-upload.jks
# 키스토어 비밀번호 (keytool 에서 입력한 값)
storePassword=여기에_키스토어_비밀번호
# 키 별칭 (keytool 의 -alias 값)
keyAlias=tickjapan
# 키 비밀번호 (보통 키스토어 비밀번호와 동일하게 설정)
keyPassword=여기에_키_비밀번호
